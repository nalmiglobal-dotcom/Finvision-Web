# WhatsApp Business API Configuration
# Get these from: https://developers.facebook.com/apps/

# WhatsApp Phone Number ID (found in WhatsApp > API Setup)
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id

# WhatsApp Access Token (generate from System Users > Generate Token)
WHATSAPP_ACCESS_TOKEN=your_permanent_access_token

# Webhook Verify Token (create your own random string)
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your_random_verify_token

# WhatsApp App Secret (optional, from App Settings > Basic)
# Used for webhook signature verification
WHATSAPP_APP_SECRET=your_app_secret

# OpenAI API Key
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key
